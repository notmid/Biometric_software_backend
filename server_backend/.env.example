# Copy this file to .env and fill in the values below.
# Never commit the real .env file — it contains secrets.

# MongoDB connection string.
#
# Option A — MongoDB Atlas (cloud, free tier, no local install):
#   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/attendance
#   (get this from Atlas -> Database -> Connect -> Drivers)
#
# Option B — local MongoDB install:
#   mongodb://127.0.0.1:27017/attendance
MONGO_URI=mongodb://naveenkrishnan27:naveen270308@ac-1avib4m-shard-00-00.exzqh0r.mongodb.net:27017,ac-1avib4m-shard-00-01.exzqh0r.mongodb.net:27017,ac-1avib4m-shard-00-02.exzqh0r.mongodb.net:27017/?ssl=true&replicaSet=atlas-4va1hg-shard-0&authSource=admin&appName=Cluster0

# Any long random string, used to sign login tokens.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ce29ef3150f652c0e6bc866202c7fa283ad28abf6243d870cf1ed440c72663de0cfb660f05fbee250f404be295e1e67b4be97bf1bebfe401e885ad10c340c4c9

# Port the server listens on. 5000 matches what the frontend expects by default.
PORT=5000

# Comma-separated list of frontend origins allowed to call this API.
# The Vite dev server defaults to 5173.
CORS_ORIGINS=http://localhost:5173

# URL of the face/liveness/speech model service (see /model-service).
# That's a separate always-on Python process — start it with
# `uvicorn server:app --port 8001` from inside model-service/ before
# adding employees with photos or using mobile check-in.
MODEL_SERVICE_URL=http://localhost:8001
