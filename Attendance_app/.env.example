# Copy to .env in the project root.
#
# "localhost" here would mean the phone itself, not your computer — so this
# must be your computer's LAN IP (find it with `ipconfig` on Windows /
# `ifconfig` or `ipconfig getifaddr en0` on Mac), with the backend's port.
# Your phone and computer need to be on the same Wi-Fi network.
EXPO_PUBLIC_API_URL=http://122.178.44.239:5000
